{
  "schema_version": "1.0",
  "template": "cli-tool",
  "project": {
    "id": "decision-log-linter",
    "name": "Decision Log Linter",
    "default_branch": "main"
  },
  "roles": {
    "pm": {
      "title": "Product Manager",
      "mandate": "Keep the CLI scope useful, crisp, and testable.",
      "write_authority": "review_only",
      "runtime": "manual-pm"
    },
    "architect": {
      "title": "Architect",
      "mandate": "Challenge parser boundaries, output shape, and error semantics.",
      "write_authority": "review_only",
      "runtime": "manual-architect"
    },
    "dev": {
      "title": "Developer",
      "mandate": "Implement the tool and keep verification honest.",
      "write_authority": "authoritative",
      "runtime": "manual-dev"
    },
    "qa": {
      "title": "QA",
      "mandate": "Challenge fixture coverage, invalid-input handling, and release readiness.",
      "write_authority": "review_only",
      "runtime": "manual-qa"
    },
    "release_manager": {
      "title": "Release Manager",
      "mandate": "Own packaging truth and release-readiness checks.",
      "write_authority": "authoritative",
      "runtime": "manual-release"
    }
  },
  "runtimes": {
    "manual-pm": { "type": "manual" },
    "manual-architect": { "type": "manual" },
    "manual-dev": { "type": "manual" },
    "manual-qa": { "type": "manual" },
    "manual-release": { "type": "manual" }
  },
  "routing": {
    "planning": {
      "entry_role": "pm",
      "allowed_next_roles": ["pm", "architect", "human"],
      "exit_gate": "planning_signoff"
    },
    "architecture": {
      "entry_role": "architect",
      "allowed_next_roles": ["architect", "dev", "human"],
      "exit_gate": "architecture_ready"
    },
    "implementation": {
      "entry_role": "dev",
      "allowed_next_roles": ["dev", "qa", "human"],
      "exit_gate": "implementation_complete"
    },
    "qa": {
      "entry_role": "qa",
      "allowed_next_roles": ["qa", "dev", "release_manager", "human"],
      "exit_gate": "qa_ship_verdict"
    },
    "release": {
      "entry_role": "release_manager",
      "allowed_next_roles": ["release_manager", "human"],
      "exit_gate": "release_ready"
    }
  },
  "gates": {
    "planning_signoff": {
      "requires_files": [
        ".planning/PM_SIGNOFF.md",
        ".planning/ROADMAP.md",
        ".planning/SYSTEM_SPEC.md"
      ],
      "requires_human_approval": true
    },
    "architecture_ready": {
      "requires_files": [
        ".planning/ARCHITECTURE.md"
      ]
    },
    "implementation_complete": {
      "requires_files": [
        ".planning/IMPLEMENTATION_NOTES.md"
      ],
      "requires_verification_pass": true
    },
    "qa_ship_verdict": {
      "requires_files": [
        ".planning/acceptance-matrix.md",
        ".planning/ship-verdict.md",
        ".planning/RELEASE_NOTES.md"
      ],
      "requires_human_approval": true
    },
    "release_ready": {
      "requires_files": [
        ".planning/distribution-checklist.md"
      ],
      "requires_verification_pass": true
    }
  },
  "workflow_kit": {
    "phases": {
      "planning": {
        "artifacts": [
          {
            "path": ".planning/PM_SIGNOFF.md",
            "semantics": "pm_signoff",
            "required": true,
            "owned_by": "pm"
          },
          {
            "path": ".planning/SYSTEM_SPEC.md",
            "semantics": "system_spec",
            "required": true,
            "owned_by": "pm"
          },
          {
            "path": ".planning/ROADMAP.md",
            "semantics": null,
            "required": true,
            "owned_by": "pm"
          },
          {
            "path": ".planning/command-surface.md",
            "semantics": "section_check",
            "required": true,
            "owned_by": "pm",
            "semantics_config": {
              "required_sections": [
                "## Primary Commands",
                "## Flags And Options",
                "## Failure UX"
              ]
            }
          },
          {
            "path": ".planning/platform-support.md",
            "semantics": "section_check",
            "required": true,
            "owned_by": "pm",
            "semantics_config": {
              "required_sections": [
                "## Supported Environments",
                "## Compatibility Risks",
                "## Manual Checks"
              ]
            }
          }
        ]
      },
      "architecture": {
        "artifacts": [
          {
            "path": ".planning/ARCHITECTURE.md",
            "semantics": "section_check",
            "required": true,
            "owned_by": "architect",
            "semantics_config": {
              "required_sections": [
                "## Context",
                "## Proposed Design",
                "## Trade-offs",
                "## Risks"
              ]
            }
          }
        ]
      },
      "implementation": {
        "artifacts": [
          {
            "path": ".planning/IMPLEMENTATION_NOTES.md",
            "semantics": "implementation_notes",
            "required": true,
            "owned_by": "dev"
          }
        ]
      },
      "qa": {
        "artifacts": [
          {
            "path": ".planning/acceptance-matrix.md",
            "semantics": "acceptance_matrix",
            "required": true,
            "owned_by": "qa"
          },
          {
            "path": ".planning/ship-verdict.md",
            "semantics": "ship_verdict",
            "required": true,
            "owned_by": "qa"
          },
          {
            "path": ".planning/RELEASE_NOTES.md",
            "semantics": "release_notes",
            "required": true,
            "owned_by": "qa"
          }
        ]
      },
      "release": {
        "artifacts": [
          {
            "path": ".planning/distribution-checklist.md",
            "semantics": "section_check",
            "required": true,
            "owned_by": "release_manager",
            "semantics_config": {
              "required_sections": [
                "## Packaging",
                "## Install Paths",
                "## Release Risks"
              ]
            }
          }
        ]
      }
    }
  },
  "prompts": {
    "pm": ".agentxchain/prompts/pm.md",
    "architect": ".agentxchain/prompts/architect.md",
    "dev": ".agentxchain/prompts/dev.md",
    "qa": ".agentxchain/prompts/qa.md",
    "release_manager": ".agentxchain/prompts/release_manager.md"
  },
  "budget": {
    "per_turn_max_usd": 1.0,
    "per_run_max_usd": 10.0,
    "on_exceed": "pause_and_escalate"
  },
  "retention": {
    "talk_strategy": "append_only",
    "history_strategy": "jsonl_append_only"
  },
  "rules": {
    "challenge_required": true,
    "max_turn_retries": 2,
    "max_deadlock_cycles": 2
  }
}
