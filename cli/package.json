{
  "name": "agentxchain",
  "version": "2.14.0",
  "description": "CLI for AgentXchain — governed multi-agent software delivery",
  "type": "module",
  "bin": {
    "agentxchain": "./bin/agentxchain.js"
  },
  "exports": {
    ".": "./bin/agentxchain.js",
    "./runner-interface": "./src/lib/runner-interface.js",
    "./run-loop": "./src/lib/run-loop.js"
  },
  "files": [
    "bin/",
    "src/",
    "dashboard/",
    "scripts/",
    "README.md"
  ],
  "scripts": {
    "dev": "node bin/agentxchain.js",
    "test": "npm run test:vitest && npm run test:node",
    "test:vitest": "vitest run --reporter=verbose",
    "test:node": "node --test test/*.test.js",
    "preflight:release": "bash scripts/release-preflight.sh",
    "preflight:release:strict": "bash scripts/release-preflight.sh --strict",
    "postflight:release": "bash scripts/release-postflight.sh",
    "postflight:downstream": "bash scripts/release-downstream-truth.sh",
    "build:macos": "bun build bin/agentxchain.js --compile --target=bun-darwin-arm64 --outfile=dist/agentxchain-macos-arm64",
    "build:linux": "bun build bin/agentxchain.js --compile --target=bun-linux-x64 --outfile=dist/agentxchain-linux-x64",
    "publish:npm": "bash scripts/publish-npm.sh"
  },
  "keywords": [
    "ai",
    "agents",
    "multi-agent",
    "sdlc",
    "governance",
    "audit-trail",
    "code-review",
    "developer-tools",
    "adversarial-collaboration",
    "orchestrator",
    "protocol",
    "claude-code",
    "agentxchain"
  ],
  "author": "shivamtiwari93",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shivamtiwari93/agentXchain.dev.git"
  },
  "homepage": "https://agentxchain.dev",
  "dependencies": {
    "@anthropic-ai/tokenizer": "0.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "inquirer": "^13.3.2",
    "ora": "^8.0.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.17.0 || >=20.5.0"
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
