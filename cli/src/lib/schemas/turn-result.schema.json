{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentxchain.dev/schemas/turn-result/v1",
  "title": "AgentXchain Turn Result v1",
  "description": "Structured output produced by every agent turn. The orchestrator validates and accepts/rejects based on this contract.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "turn_id",
    "role",
    "runtime_id",
    "status",
    "summary",
    "decisions",
    "objections",
    "files_changed",
    "verification",
    "artifact",
    "proposed_next_role"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0",
      "description": "Must be '1.0' for v1 turn results."
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "description": "Must match the current run. Format: run_XXXX..."
    },
    "turn_id": {
      "type": "string",
      "minLength": 1,
      "description": "Must match the current turn assignment. Format: turn-NNNN"
    },
    "role": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$",
      "description": "Must match the role assigned for this turn."
    },
    "runtime_id": {
      "type": "string",
      "minLength": 1,
      "description": "The runtime that executed this turn."
    },
    "status": {
      "enum": ["completed", "blocked", "needs_human", "failed"],
      "description": "Outcome of this turn."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable summary of what happened."
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "statement", "rationale"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^DEC-\\d+$",
            "description": "Decision ID, e.g. DEC-014"
          },
          "category": {
            "enum": ["implementation", "architecture", "scope", "process", "quality", "release"]
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "durability": {
            "type": "string",
            "enum": ["run", "repo"],
            "description": "Decision persistence scope. 'run' (default) dies with the run; 'repo' persists across runs as a binding constraint."
          },
          "overrides": {
            "type": "string",
            "pattern": "^DEC-\\d+$",
            "description": "ID of an active repo-durable decision this decision supersedes."
          }
        }
      }
    },
    "objections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "statement"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^OBJ-\\d+$",
            "description": "Objection ID, e.g. OBJ-007"
          },
          "severity": {
            "enum": ["low", "medium", "high", "blocking"]
          },
          "against_turn_id": {
            "type": "string",
            "description": "Turn that this objection challenges."
          },
          "against_decision_id": {
            "type": "string",
            "description": "Decision ID being challenged."
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "proposed_resolution": {
            "type": "string"
          },
          "status": {
            "enum": ["raised", "acknowledged", "resolved", "escalated", "resolved_by_human", "resolved_by_director"],
            "default": "raised"
          }
        }
      }
    },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Paths of files modified during this turn. Workspace artifacts must declare a non-empty list that matches observed diff. Review artifacts must use an empty list."
    },
    "artifacts_created": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Paths of planning/review artifacts created (under .planning/ or .agentxchain/)."
    },
    "verification": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "enum": ["pass", "fail", "skipped"],
          "description": "Raw status from agent. Orchestrator may normalize to attested_pass or not_reproducible."
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "\\S"
          },
          "description": "Verification commands that were run."
        },
        "evidence_summary": {
          "type": "string",
          "description": "Human-readable description of verification evidence."
        },
        "machine_evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["command", "exit_code"],
            "properties": {
              "command": {
                "type": "string",
                "pattern": "\\S"
              },
              "exit_code": { "type": "integer" }
            }
          }
        },
        "produced_files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path"],
            "additionalProperties": false,
            "properties": {
              "path": { "type": "string" },
              "disposition": {
                "enum": ["artifact", "ignore"]
              }
            }
          }
        }
      }
    },
    "artifact": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["workspace", "patch", "commit", "review"],
          "description": "workspace = direct repo file changes with non-empty files_changed, patch = unified diff, commit = git commit, review = no repo mutations with files_changed: []"
        },
        "ref": {
          "type": ["string", "null"],
          "description": "Git SHA, patch path, or null for review-only."
        },
        "diff_summary": {
          "type": "string"
        }
      }
    },
    "proposed_next_role": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$|^human$",
      "description": "Role that should work next. Must be in routing allowlist or 'human'."
    },
    "phase_transition_request": {
      "type": ["string", "null"],
      "description": "If the agent believes the phase should advance, name the target phase."
    },
    "run_completion_request": {
      "type": ["boolean", "null"],
      "description": "Set to true only in the final phase when the run should complete. Mutually exclusive with phase_transition_request."
    },
    "needs_human_reason": {
      "type": ["string", "null"],
      "description": "If status is needs_human, explain why."
    },
    "proposed_changes": {
      "type": "array",
      "description": "Structured file proposals for proposed write authority turns via api_proxy. Orchestrator materializes these to .agentxchain/proposed/<turn_id>/.",
      "items": {
        "type": "object",
        "required": ["path", "action"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Repo-relative file path for the proposed change."
          },
          "action": {
            "enum": ["create", "modify", "delete"],
            "description": "Type of file change being proposed."
          },
          "content": {
            "type": "string",
            "description": "Full file content for create/modify actions. Required for create and modify, ignored for delete."
          },
          "original_snippet": {
            "type": "string",
            "description": "Optional snippet of the original code being replaced (for modify actions)."
          }
        }
      }
    },
    "idle_expansion_result": {
      "type": "object",
      "description": "Required only for vision_idle_expansion turns. PM output that either proposes the next intake intent or declares the product vision exhausted.",
      "required": ["kind", "expansion_iteration", "vision_traceability"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": ["new_intake_intent", "vision_exhausted"]
        },
        "expansion_iteration": {
          "type": "integer",
          "minimum": 1
        },
        "vision_traceability": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["vision_heading"],
            "additionalProperties": false,
            "properties": {
              "vision_heading": { "type": "string", "minLength": 1 },
              "goal": { "type": "string", "minLength": 1 },
              "kind": { "enum": ["advances", "supports", "unblocks"] }
            }
          }
        },
        "new_intake_intent": {
          "type": "object",
          "required": ["title", "charter", "acceptance_contract", "priority", "template"],
          "additionalProperties": false,
          "properties": {
            "title": { "type": "string", "minLength": 1 },
            "charter": { "type": "string", "minLength": 1 },
            "acceptance_contract": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "priority": { "enum": ["p0", "p1", "p2", "p3"] },
            "template": {
              "enum": ["generic", "api-service", "cli-tool", "library", "web-app", "full-local-cli", "enterprise-app"]
            }
          }
        },
        "vision_exhausted": {
          "type": "object",
          "required": ["classification"],
          "additionalProperties": false,
          "properties": {
            "classification": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["vision_heading", "status", "reason"],
                "additionalProperties": false,
                "properties": {
                  "vision_heading": { "type": "string", "minLength": 1 },
                  "status": { "enum": ["complete", "deferred", "out_of_scope"] },
                  "reason": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    },
    "cost": {
      "type": "object",
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "usd": { "type": "number", "minimum": 0 }
      }
    },
    "delegations": {
      "type": "array",
      "description": "Sub-tasks delegated to other roles. The delegating role defines the charter; delegates execute it; the delegating role reviews results.",
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "to_role", "charter", "acceptance_contract"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^del-\\d{3}$",
            "description": "Delegation ID, e.g. del-001"
          },
          "to_role": {
            "type": "string",
            "pattern": "^[a-z0-9_-]+$",
            "description": "Role that should execute this sub-task. Must be a defined role and routing-legal."
          },
          "charter": {
            "type": "string",
            "minLength": 1,
            "description": "Scope of the delegated work."
          },
          "acceptance_contract": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1,
            "description": "What the delegate must achieve for this delegation to be considered complete."
          },
          "required_decision_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^DEC-\\d+$"
            },
            "minItems": 1,
            "uniqueItems": true,
            "description": "Optional named decisions the delegated child must emit before the parent review turn may advance phase/run lifecycle."
          }
        }
      }
    }
  }
}
